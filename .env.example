RECEIPT_TEXT_PROVIDER=auto
GEMINI_RECEIPT_MODEL=gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash
RECEIPT_UPLOAD_MAX_FILE_SIZE_BYTES=10485760
RECEIPT_BULK_UPLOAD_MAX_FILES=10
RECEIPT_PROCESSING_TTL_HOURS=1
RECEIPT_OCR_JPEG_QUALITY=85
RECEIPT_OCR_MAX_IMAGE_DIMENSION=1600
RECEIPT_OCR_MIN_JPEG_QUALITY=55
RECEIPT_OCR_TARGET_MAX_BYTES=307200
RECEIPT_OCR_JOB_TTL_HOURS=24
RECEIPT_OCR_JOB_MAX_ATTEMPTS=2
RECEIPT_OCR_QUEUE_BATCH_SIZE=1
OCR_READTEXT_TIMEOUT_SECONDS=40
OCR_ENABLE_EXTRA_VARIANTS=false
# CRON_CLEAN_RECEIPT_PROCESSING_IMAGES=0 * * * *
# CRON_PROCESS_RECEIPT_OCR_QUEUE=*/10 * * * * *

# DigitalOcean SSH Connectivity Check
# Used by: npm run deploy:test-ssh
DO_HOST=
DO_USERNAME=root
DO_SSH_PORT=22
# DO_SSH_KEY_PATH=~/.ssh/your_droplet_key

