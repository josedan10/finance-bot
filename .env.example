TELEGRAM_BOT_TOKEN=XXXXXXXXXXXXXX
PORT=5000
TEST_CHAT_ID=XXXXXXXXX
DATABASE_URL="XXXXXXXXXX"
# IG_USERNAME="XXXXXXXXXX"
# IG_PASSWORD="XXXXXXXXXX"
# APP_MODE="production"
# SAVE_SCREENSHOTS="1"
IMAGE_2_TEXT_SERVICE_URL="http://zentra-image-extractor:4000/"
RECEIPT_UPLOAD_MAX_FILE_SIZE_BYTES=10485760

# DigitalOcean SSH Connectivity Check
# Used by: npm run deploy:test-ssh
DO_HOST=
DO_USERNAME=root
DO_SSH_PORT=22
# DO_SSH_KEY_PATH=~/.ssh/your_droplet_key

# Gmail Integration
# GMAIL_CREDENTIALS_PATH=./credentials.json
# GMAIL_TOKEN_PATH=./token.json
# GMAIL_POLL_QUERY=is:unread category:updates
# CRON_CHECK_GMAIL=0 */30 * * 1-5

# Firebase Admin SDK
# You can use GOOGLE_APPLICATION_CREDENTIALS path or inline JSON
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Sentry Observability
# SENTRY_DSN=
# OCR_SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
# SENTRY_TEST_ENDPOINTS_ENABLED=false
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# OCR_SENTRY_DSN=

# Web Push Notifications (VAPID Keys)
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@financebot.com
