datasource db {
  url      = env("DATABASE_URL")
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  admin
  user
  operator
  dev
  support
}

enum AIProvider {
  GEMINI
  CHATGPT
}

model User {
  id         Int      @id @default(autoincrement())
  firebaseId String   @unique @db.VarChar(128)
  email      String   @unique @db.VarChar(255)
  createdAt  DateTime @default(now())

  // Relationships to tenant-scoped entities
  categories              Category[]
  keywords                Keyword[]
  paymentMethods          PaymentMethod[]
  transactions            Transaction[]
  suscriptions            Suscription[]
  shops                   Shop[]
  platformMonthlyRegister PlatformMonthlyRegister[]
  
  // Notification relationships
  notificationPreferences NotificationPreference[]
  notificationLogs        NotificationLog[]
  pushSubscriptions      PushSubscription[]
  
  // AI relationships
  aiSettings              AISettings?
}

model Category {
  id              Int               @id @default(autoincrement())
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          Int
  name            String            @db.VarChar(20)
  description     String?           @db.VarChar(255)
  amountLimit     Decimal?          @db.Decimal(10, 2)
  transaction     Transaction[]
  shopCategory    ShopCategory[]
  categoryKeyword CategoryKeyword[]
  notificationLogs NotificationLog[]

  @@unique([name, userId])
}

model Keyword {
  id              Int               @id @default(autoincrement())
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          Int
  name            String            @db.VarChar(100)
  description     String?           @db.VarChar(255)
  categoryKeyword CategoryKeyword[]

  @@unique([name, userId])
}

model CategoryKeyword {
  id         Int      @id @default(autoincrement())
  categoryId Int
  keywordId  Int
  category   Category @relation(fields: [categoryId], references: [id])
  keyword    Keyword  @relation(fields: [keywordId], references: [id])

  @@unique([categoryId, keywordId])
}

model PaymentMethod {
  id                      Int                       @id @default(autoincrement())
  user                    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                  Int
  name                    String                    @db.VarChar(20)
  transaction             Transaction[]
  platformMonthlyRegister PlatformMonthlyRegister[]

  @@unique([name, userId])
}

model Transaction {
  id                     Int            @id @default(autoincrement())
  user                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 Int
  date                   DateTime
  description            String?        @db.VarChar(255)
  amount                 Decimal?       @db.Decimal(10, 2)
  originalCurrencyAmount Decimal?       @db.Decimal(10, 2)
  referenceId            String?        @db.VarChar(30)
  currency               String         @db.VarChar(3)
  type                   String         @db.VarChar(10)
  isMonthly              Boolean        @default(false)
  isAnnually             Boolean        @default(false)
  telegramFileIds        String?        @db.VarChar(255)
  category               Category?      @relation(fields: [categoryId], references: [id])
  categoryId             Int?
  shopId                 Int?
  shop                   Shop?          @relation(fields: [shopId], references: [id])
  paymentMethod          PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  paymentMethodId        Int?
  reviewed               Boolean        @default(false)
  reviewedAt             DateTime?

  @@unique(fields: [description, referenceId, date, userId])
}

model PlatformMonthlyRegister {
  id              Int           @id @default(autoincrement())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          Int
  startAmount     Decimal       @db.Decimal(10, 2)
  endAmount       Decimal       @db.Decimal(10, 2)
  year            Int           @db.Int
  month           Int           @db.Int
  paymentMethodId Int
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@unique([paymentMethodId, year, month, userId])
  @@index([paymentMethodId, year, month])
}

model Suscription {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  name        String  @db.VarChar(20)
  keyWord     String? @db.VarChar(20)
  paymentDate String? @db.VarChar(10)
  type        String  @db.VarChar(20)

  @@unique([name, userId])
}

model Shop {
  id           Int            @id @default(autoincrement())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  name         String         @db.VarChar(20)
  keyWord      String?        @db.VarChar(20)
  shopCategory ShopCategory[]
  transaction  Transaction[]

  @@unique([name, userId])
}

model ShopCategory {
  id         Int      @id @default(autoincrement())
  categoryId Int
  shopId     Int
  category   Category @relation(fields: [categoryId], references: [id])
  shop       Shop     @relation(fields: [shopId], references: [id])
}

model DailyExchangeRate {
  id           Int      @id @default(autoincrement())
  monitorPrice Decimal? @db.Decimal(10, 2)
  bcvPrice     Decimal? @db.Decimal(10, 2)
  date         DateTime @unique
  createdAt    DateTime @default(now())

  @@index([date])
}

model ProcessedEmail {
  id        Int      @id @default(autoincrement())
  messageId String   @unique @db.VarChar(255)
  from      String   @db.VarChar(255)
  subject   String   @db.VarChar(500)
  result    String?  @db.Text
  createdAt DateTime @default(now())
}

model TaskQueue {
  id                Int       @id @default(autoincrement())
  body              String?   @db.Text()
  type              String    @db.VarChar(100)
  status            String    @default("pending") @db.VarChar(15)
  attemptsRemaining Int       @default(10) @db.Int
  createdBy         String?   @db.VarChar(20)
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  @@index([type, status])
}

// ============================================
// Notification Models
// ============================================

model NotificationPreference {
  id                  Int       @id @default(autoincrement())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              Int       @unique
  emailEnabled        Boolean   @default(true)
  webPushEnabled      Boolean   @default(true)
  thresholds          String    @default("[50, 70, 90]") @db.VarChar(50)  // JSON array as string: "[50,70,90]"
  disabledCategories  String?   @db.VarChar(255)  // JSON array of category IDs to skip
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model NotificationLog {
  id            Int       @id @default(autoincrement())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId    Int
  channel       String    @db.VarChar(20)  // "email" | "webpush"
  threshold     Int       // 50 | 70 | 90
  percentage    Decimal   @db.Decimal(5, 2)  // Actual percentage when triggered
  status        String    @default("sent") @db.VarChar(10)  // "sent" | "failed"
  errorMessage  String?   @db.Text()
  createdAt     DateTime  @default(now())

  @@index([userId, categoryId, createdAt])
  @@index([userId, channel, createdAt])
}

// Web Push Subscriptions for browser notifications
model PushSubscription {
  id          Int       @id @default(autoincrement())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  endpoint    String    @db.Text  // Push subscription endpoint URL
  p256dh      String    @db.VarChar(100)  // ECDH public key
  auth        String    @db.VarChar(50)   // Auth secret
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime? // Subscription expiration (if any)

  @@index([userId])
}

// ============================================
// AI Assistant Models
// ============================================

model AISettings {
  id         Int        @id @default(autoincrement())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int        @unique
  aiEnabled  Boolean    @default(false)
  aiProvider AIProvider @default(GEMINI)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
}
